{
  "request": {
    "method": "GET",
    "urlPathPattern": "/catalog/products/.*"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "{{request.pathSegments.[2]}}",
      "category": "beverages",
      "popularity": 87
    },
    "transformers": ["response-template"]
  }
}
